  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Manrope:wght@300..800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">

  <style>
    :root {
      --bg: #f8fafc;
      --bg-soft: #f1f5f9;
      --ink: #0f3460;
      --ink-deep: #0a2240;
      --slate: #64748b;
      --slate-light: #94a3b8;
      --primary: #0f4c81;
      --primary-deep: #0a2f52;
      --accent: #1abc9c;
      --accent-soft: rgba(26,188,156,0.12);
      --surface: #ffffff;
      --shadow-sm: 0 2px 8px rgba(15,52,96,0.06);
      --shadow-md: 0 8px 24px rgba(15,52,96,0.10);
      --shadow-lg: 0 20px 50px rgba(15,52,96,0.14);
      --shadow-accent: 0 8px 24px rgba(26,188,156,0.25);
      --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
      --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; margin: 0; padding: 0; overflow-x: hidden; }
    body {
      font-family: 'Manrope', sans-serif;
      color: var(--ink);
      background: var(--bg);
      -webkit-font-smoothing: antialiased;
      line-height: 1.65;
      font-size: 15px;
      margin: 0; padding: 0;
      overflow-x: hidden;
    }
    .font-display { font-family: 'Fraunces', serif; }

    /* Grain overlay */
    body::after {
      content: ''; position: fixed; inset: 0; opacity: 0.025;
      pointer-events: none; z-index: 9998;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-repeat: repeat; background-size: 256px 256px;
    }

    ::selection { background: rgba(26,188,156,0.25); color: var(--ink-deep); }

    /* ===== NAVBAR ===== */
    .navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 50; transition: all 0.4s var(--ease-out); }
    .navbar-inner { max-width: 1200px; margin: 0 auto; padding: 18px 28px; display: flex; align-items: center; justify-content: space-between; }
    .navbar-glass { background: rgba(15, 52, 96, 0.88); backdrop-filter: blur(16px) saturate(140%); border-bottom: 1px solid rgba(255,255,255,0.06); }
    .nav-logo { font-family: 'Fraunces', serif; font-size: 22px; font-weight: 600; color: #fff; text-decoration: none; letter-spacing: -0.01em; }
    .nav-links { display: flex; align-items: center; gap: 36px; }
    .nav-links a { color: rgba(255,255,255,0.65); text-decoration: none; font-size: 13px; font-weight: 500; transition: color 0.3s var(--ease-out); letter-spacing: 0.04em; text-transform: uppercase; }
    .nav-links a:hover { color: #fff; }
    .nav-cta { display: inline-flex; align-items: center; gap: 8px; background: var(--accent); color: #fff; text-decoration: none; padding: 10px 24px; border-radius: 999px; font-size: 13px; font-weight: 700; transition: all 0.35s var(--ease-out); letter-spacing: 0.01em; font-family: 'Manrope', sans-serif; }
    .nav-cta:hover { transform: scale(1.05); box-shadow: 0 6px 20px rgba(26,188,156,0.35); }
    .nav-cta .icon-wrap { width: 16px; height: 16px; display: flex; align-items: center; justify-content: center; }
    .nav-cta .icon-wrap i { font-size: 14px; }
    .nav-hamburger { display: none; flex-direction: column; gap: 5px; padding: 8px; background: none; border: none; cursor: pointer; }
    .nav-hamburger span { display: block; width: 22px; height: 2px; background: #fff; border-radius: 2px; transition: all 0.3s; }
    .nav-mobile { display: none; overflow: hidden; background: rgba(15,52,96,0.95); backdrop-filter: blur(12px); }
    .nav-mobile.open { display: block; }
    .nav-mobile-inner { padding: 0 28px 24px; display: flex; flex-direction: column; gap: 14px; }
    .nav-mobile-inner a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; font-weight: 500; }

    @media (max-width: 768px) { .nav-links { display: none; } .nav-hamburger { display: flex; } }

    /* ===== HERO ===== */
    .hero {
      min-height: 100vh; display: flex; align-items: center;
      background:
        radial-gradient(ellipse 90% 80% at 20% 10%, rgba(26,188,156,0.12) 0%, transparent 55%),
        radial-gradient(ellipse 70% 60% at 85% 85%, rgba(15,76,129,0.45) 0%, transparent 50%),
        radial-gradient(ellipse 50% 40% at 50% 50%, rgba(26,188,156,0.06) 0%, transparent 50%),
        linear-gradient(160deg, #0a2240 0%, #0f3460 40%, #0f4c81 100%);
      position: relative; overflow: hidden;
      clip-path: polygon(0 0, 100% 0, 100% 92%, 0 100%);
    }
    .hero-spotlight { position: absolute; inset: 0; pointer-events: none; z-index: 1; opacity: 0; transition: opacity 0.8s ease; }
    .hero-spotlight.active { opacity: 1; }
    .hero .bubble { position: absolute; border-radius: 50%; background: radial-gradient(circle, rgba(26,188,156,0.28) 0%, transparent 70%); pointer-events: none; animation: float 7s ease-in-out infinite; filter: blur(1px); }
    .hero .bubble:nth-child(1) { width: 340px; height: 340px; top: 8%; left: -8%; animation-delay: 0s; }
    .hero .bubble:nth-child(2) { width: 220px; height: 220px; top: 58%; right: 8%; animation-delay: 2.5s; background: radial-gradient(circle, rgba(255,255,255,0.10) 0%, transparent 70%); }
    .hero .bubble:nth-child(3) { width: 160px; height: 160px; top: 28%; right: 28%; animation-delay: 4.5s; }
    .hero .bubble:nth-child(4) { width: 100px; height: 100px; bottom: 15%; left: 15%; animation-delay: 1.5s; background: radial-gradient(circle, rgba(26,188,156,0.18) 0%, transparent 70%); }
    .hero .bubble:nth-child(5) { width: 180px; height: 180px; top: 45%; left: 45%; animation-delay: 3.5s; background: radial-gradient(circle, rgba(15,76,129,0.3) 0%, transparent 70%); }
    @keyframes float { 0%, 100% { transform: translateY(0) rotate(0deg) scale(1); } 50% { transform: translateY(-24px) rotate(3deg) scale(1.06); } }

    .hero-inner { max-width: 1200px; margin: 0 auto; padding: 140px 28px 120px; width: 100%; position: relative; z-index: 2; }
    .hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10); color: var(--accent); padding: 8px 18px; border-radius: 999px; font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 32px; transition: opacity 0.2s linear; }
    .hero-badge .icon-wrap { width: 14px; height: 14px; display: flex; align-items: center; justify-content: center; }
    .hero-badge .icon-wrap i { font-size: 12px; }
    .hero h1 { font-family: 'Fraunces', serif; font-size: clamp(44px, 6.5vw, 78px); font-weight: 600; line-height: 1.05; color: #fff; margin-bottom: 24px; max-width: 820px; letter-spacing: -0.03em; text-wrap: balance; transition: opacity 0.2s linear; }
    .hero h1 em { font-style: italic; color: var(--accent); }
    .hero-sub { font-size: 18px; color: rgba(255,255,255,0.65); max-width: 540px; margin-bottom: 36px; line-height: 1.7; font-weight: 400; transition: opacity 0.2s linear; }
    .hero-btns { display: flex; flex-wrap: wrap; gap: 14px; margin-bottom: 48px; transition: opacity 0.2s linear; }
    .btn-primary { display: inline-flex; align-items: center; gap: 10px; background: var(--accent); color: #fff; text-decoration: none; padding: 16px 34px; border-radius: 999px; font-size: 14px; font-weight: 700; transition: all 0.4s var(--ease-out); letter-spacing: 0.01em; border: 1px solid transparent; position: relative; overflow: hidden; font-family: 'Manrope', sans-serif; }
    .btn-primary::before { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent); transition: left 0.5s; }
    .btn-primary:hover::before { left: 100%; }
    .btn-primary:hover { transform: scale(1.04); box-shadow: 0 12px 32px rgba(26,188,156,0.35); background: #17a689; }
    .btn-primary .icon-wrap { width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; }
    .btn-primary .icon-wrap i { font-size: 18px; }
    .btn-ghost { display: inline-flex; align-items: center; gap: 10px; color: #fff; text-decoration: none; padding: 16px 34px; border-radius: 999px; font-size: 14px; font-weight: 600; border: 1px solid rgba(255,255,255,0.28); transition: all 0.4s var(--ease-out); background: rgba(255,255,255,0.06); font-family: 'Manrope', sans-serif; position: relative; overflow: hidden; backdrop-filter: blur(4px); }
    .btn-ghost:hover { background: rgba(255,255,255,0.14); border-color: rgba(255,255,255,0.55); box-shadow: 0 0 24px rgba(255,255,255,0.12); }
    .btn-ghost .icon-wrap { width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; }
    .btn-ghost .icon-wrap i { font-size: 18px; transition: transform 0.4s var(--ease-spring); }
    .btn-ghost:hover .icon-wrap i { transform: translateY(3px); }
    .hero-social { display: flex; align-items: center; gap: 14px; margin-bottom: 56px; transition: opacity 0.2s linear; }
    .hero-social .stars { display: flex; align-items: center; gap: 3px; }
    .hero-social .stars .icon-wrap { width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; }
    .hero-social .stars .icon-wrap i { font-size: 14px; color: var(--accent); }
    .hero-social span { font-size: 13px; color: rgba(255,255,255,0.45); font-weight: 500; }

    .hero-stats { display: grid; grid-template-columns: repeat(3, 1fr); background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; overflow: hidden; max-width: 620px; backdrop-filter: blur(8px); }
    .hero-stats .stat { text-align: center; padding: 28px 20px; position: relative; }
    .hero-stats .stat:not(:last-child)::after { content: ''; position: absolute; right: 0; top: 25%; bottom: 25%; width: 1px; background: linear-gradient(180deg, transparent, rgba(255,255,255,0.12), transparent); }
    .hero-stats .stat-num { font-family: 'Fraunces', serif; font-size: 34px; font-weight: 600; color: #fff; line-height: 1; letter-spacing: -0.02em; }
    .hero-stats .stat-label { font-size: 11px; color: rgba(255,255,255,0.45); margin-top: 6px; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 500; }

    @media (max-width: 640px) { .hero { clip-path: polygon(0 0, 100% 0, 100% 96%, 0 100%); } .hero h1 { font-size: 36px; } .hero-sub { font-size: 15px; } .hero-stats .stat-num { font-size: 26px; } .hero-stats { border-radius: 16px; } }

    /* ===== SECTIONS COMMON ===== */
    .section { padding: 120px 28px; }
    .section-inner { max-width: 1200px; margin: 0 auto; }
    .text-center { text-align: center; }
    .section-label { font-size: 11px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); margin-bottom: 14px; display: inline-block; }
    .section h2 { font-family: 'Fraunces', serif; font-size: clamp(34px, 4.2vw, 52px); font-weight: 600; color: var(--ink); line-height: 1.1; margin-bottom: 18px; letter-spacing: -0.02em; text-wrap: balance; }
    .section h2 em { font-style: italic; color: var(--primary); }
    .section p { color: var(--slate); font-size: 15px; line-height: 1.75; }
    .divider { width: 48px; height: 3px; background: var(--accent); border-radius: 2px; margin: 20px 0 24px; transition: width 0.8s var(--ease-out); }
    .divider.animated { width: 48px; }

    @media (max-width: 640px) { .section { padding: 72px 24px; } }

    /* ===== PROBLEMA ===== */
    .problema-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 64px; align-items: center; }
    .problema-list { list-style: none; margin-top: 28px; }
    .problema-list li { display: flex; align-items: flex-start; gap: 14px; padding: 14px 0; font-size: 15px; color: var(--slate); border-bottom: 1px solid rgba(0,0,0,0.04); transition: all 0.3s var(--ease-out); }
    .problema-list li:hover { transform: translateX(8px); color: var(--ink); }
    .problema-list .icon-wrap { width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; }
    .problema-list .icon-wrap i { font-size: 16px; color: #e06c75; }
    .problema-visual { background: linear-gradient(160deg, var(--primary) 0%, var(--primary-deep) 100%); border-radius: 24px; padding: 48px; color: #fff; position: relative; overflow: hidden; box-shadow: var(--shadow-lg); border: 1px solid rgba(255,255,255,0.06); transform: perspective(1000px) rotateY(-5deg) rotateX(2deg); transition: transform 0.5s var(--ease-out); }
    .problema-visual:hover { transform: perspective(1000px) rotateY(0deg) rotateX(0deg); }
    .problema-visual::before { content: ''; position: absolute; top: -40px; right: -40px; width: 160px; height: 160px; border-radius: 50%; background: rgba(26,188,156,0.08); pointer-events: none; }
    .problema-visual .icon-wrap { width: 64px; height: 64px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; }
    .problema-visual .icon-wrap i { font-size: 44px; color: rgba(255,255,255,0.2); }
    .problema-visual h3 { font-family: 'Fraunces', serif; font-size: 26px; font-weight: 600; margin-bottom: 10px; line-height: 1.2; }
    .problema-visual p { color: rgba(255,255,255,0.65); font-size: 14px; }

    @media (max-width: 768px) { .problema-grid { grid-template-columns: 1fr; gap: 40px; } .problema-visual { transform: none; } }

    /* ===== SOBRE ===== */
    .sobre-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
    .sobre-foto-wrap { position: relative; }
    .sobre-foto { border-radius: 24px; overflow: hidden; box-shadow: var(--shadow-lg); aspect-ratio: 3/4; transform: rotate(-2deg); transition: transform 0.5s var(--ease-out); border: 1px solid rgba(0,0,0,0.06); }
    .sobre-foto:hover { transform: rotate(0deg) scale(1.02); }
    .sobre-foto img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .sobre-badge { position: absolute; bottom: -18px; right: -12px; background: var(--surface); border: 1px solid rgba(0,0,0,0.06); border-radius: 16px; padding: 14px 22px; box-shadow: var(--shadow-md); z-index: 2; animation: pulse-badge 2s ease-in-out infinite; }
    @keyframes pulse-badge { 0%, 100% { box-shadow: var(--shadow-md); } 50% { box-shadow: 0 8px 32px rgba(26,188,156,0.3); } }
    .sobre-badge-label { font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent); margin-bottom: 2px; }
    .sobre-badge-num { font-family: 'Fraunces', serif; font-size: 22px; font-weight: 600; color: var(--ink); }

    .sobre-sem-foto { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
    .sobre-card { position: relative; overflow: hidden; background: linear-gradient(160deg, var(--primary) 0%, var(--accent) 100%); border-radius: 28px; aspect-ratio: 1/1; display: flex; flex-direction: column; align-items: center; justify-content: center; box-shadow: var(--shadow-lg); border: 1px solid rgba(255,255,255,0.08); min-height: 280px; max-height: 420px; transform: perspective(1000px) rotateY(5deg) rotateX(-2deg); transition: transform 0.5s var(--ease-out); }
    .sobre-card:hover { transform: perspective(1000px) rotateY(0deg) rotateX(0deg); }
    .sobre-card::before { content: ''; position: absolute; inset: 0; pointer-events: none; opacity: 0.25; background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.12'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); }
    .sobre-card::after { content: ''; position: absolute; top: -40px; right: -40px; width: 160px; height: 160px; border-radius: 50%; background: radial-gradient(circle, rgba(26,188,156,0.18) 0%, transparent 70%); pointer-events: none; }
    .sobre-card-inicial { font-family: 'Fraunces', serif; font-size: 88px; font-weight: 600; color: #fff; line-height: 1; letter-spacing: -0.03em; z-index: 1; }
    .sobre-card .icon-wrap { width: 52px; height: 52px; display: flex; align-items: center; justify-content: center; margin-top: 14px; z-index: 1; }
    .sobre-card .icon-wrap i { font-size: 36px; color: rgba(255,255,255,0.45); }
    .sobre-card-badge { position: absolute; bottom: 16px; right: 16px; background: rgba(255,255,255,0.95); border-radius: 14px; padding: 10px 16px; text-align: left; box-shadow: var(--shadow-sm); z-index: 1; }
    .sobre-texto { text-align: left; }
    .sobre-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
    .sobre-tag { display: inline-flex; align-items: center; gap: 6px; background: var(--accent-soft); color: var(--primary); padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 600; transition: all 0.3s var(--ease-out); }
    .sobre-tag:hover { transform: translateY(-2px); box-shadow: var(--shadow-sm); }
    .sobre-tag .icon-wrap { width: 14px; height: 14px; display: flex; align-items: center; justify-content: center; }
    .sobre-tag .icon-wrap i { font-size: 12px; }
    .sobre-card-badge-label { font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent); }
    .sobre-card-badge-num { font-family: 'Fraunces', serif; font-size: 18px; font-weight: 600; color: var(--ink); }

    @media (max-width: 768px) { .sobre-grid { grid-template-columns: 1fr; } .sobre-sem-foto { grid-template-columns: 1fr; } .sobre-foto { transform: rotate(0deg); } .sobre-card { min-height: 240px; max-height: 320px; transform: none; aspect-ratio: 4/3; } }

    /* ===== SERVIÇOS ===== */
    .servicos-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 40px; }
    .service-card { background: var(--surface); border-radius: 28px; padding: 36px; border: 1px solid rgba(0,0,0,0.04); transition: all 0.5s var(--ease-out); position: relative; overflow: hidden; transform-style: preserve-3d; perspective: 1000px; box-shadow: var(--shadow-sm); }
    .service-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: linear-gradient(180deg, var(--accent), var(--primary)); opacity: 0; transition: opacity 0.4s var(--ease-out); }
    .service-card::after { content: ''; position: absolute; inset: 0; border-radius: 28px; padding: 1.5px; background: linear-gradient(160deg, var(--accent), transparent 60%); -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0); -webkit-mask-composite: xor; mask-composite: exclude; opacity: 0; transition: opacity 0.5s var(--ease-out); pointer-events: none; }
    .service-card:hover { transform: translateY(-10px) rotateX(3deg); box-shadow: var(--shadow-lg); border-color: transparent; }
    .service-card:hover::before { opacity: 1; }
    .service-card:hover::after { opacity: 1; }
    .service-card-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 20px; }
    .service-icon-wrap { width: 52px; height: 52px; border-radius: 14px; background: linear-gradient(160deg, var(--primary) 0%, var(--accent) 100%); display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-sm); transition: transform 0.3s var(--ease-out); }
    .service-card:hover .service-icon-wrap { transform: scale(1.1) rotate(-5deg); }
    .service-icon-wrap i { font-size: 24px; color: #fff; }
    .service-num { font-family: 'Fraunces', serif; font-size: 52px; font-weight: 600; color: var(--accent); opacity: 0.18; line-height: 1; }
    .service-card h3 { font-family: 'Fraunces', serif; font-size: 19px; font-weight: 600; color: var(--ink); margin-bottom: 8px; }
    .service-card p { font-size: 14px; color: var(--slate); line-height: 1.7; }

    @media (max-width: 640px) { .servicos-grid { grid-template-columns: 1fr; } }

    /* ===== COMO FUNCIONA ===== */
    .como-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; margin-top: 40px; position: relative; }
    .como-connector { position: absolute; top: 32px; left: 18%; right: 18%; height: 1px; background: linear-gradient(90deg, transparent, var(--accent) 20%, var(--accent) 80%, transparent); opacity: 0.30; }
    .como-step { text-align: center; position: relative; z-index: 1; }
